# DocuSign — JWT Auth (https://developers.docusign.com/platform/auth/jwt/)
DOCUSIGN_INTEGRATION_KEY=your_integration_key_here
DOCUSIGN_USER_ID=your_user_id_guid_here
DOCUSIGN_ACCOUNT_ID=your_account_id_here
# Private key: paste RSA key with literal \n for newlines
DOCUSIGN_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# Use https://demo.docusign.net/restapi for sandbox or https://na4.docusign.net/restapi for production
DOCUSIGN_BASE_PATH=https://demo.docusign.net/restapi

# DocuSign Maestro
# OAuth server: account-d.docusign.com (sandbox) | account.docusign.com (production)
DOCUSIGN_AUTH_SERVER=account-d.docusign.com
# Maestro API base: https://api-d.docusign.com/v1 (sandbox) | https://api.docusign.com/v1 (production)
DOCUSIGN_MAESTRO_BASE_URL=https://api-d.docusign.com/v1
# Workflow ID (already hardcoded in the route, but can override via env)
DOCUSIGN_MAESTRO_WORKFLOW_ID=0359ae48-47dc-45be-a7b8-9ae20894eaba
